   Common = false,
   RarityFixedCommon = false,
   RaritySpecified = false,
   RaritySpecifiedFixed = false,
}

local CrateColors = {
   LockpickCrate = Color3.fromRGB(255, 255, 255),
   LockpickCrate_Contraband = Color3.fromRGB(255, 50, 50),
   LockpickCrate_Restricted = Color3.fromRGB(255, 150, 0),
   LockpickCrate_Prototype = Color3.fromRGB(0, 150, 255),
   LockpickCrate_Specialist = Color3.fromRGB(180, 0, 255),
   Common = Color3.fromRGB(180, 180, 180),
   RarityFixedCommon = Color3.fromRGB(100, 220, 100),
   RaritySpecified = Color3.fromRGB(0, 180, 255),
   RaritySpecifiedFixed = Color3.fromRGB(255, 215, 0),
}

local function RemoveCrateESP(crate)
   if CrateESPObjects[crate] then
      for _, obj in pairs(CrateESPObjects[crate]) do
         if obj and obj.Parent then
            obj:Destroy()
         end
      end
      CrateESPObjects[crate] = nil
   end
end

-- FIXED: switched from SelectionBox to Highlight, handles nested Models
local function GetCratePart(crate)
   if crate:IsA("BasePart") then
      return crate
   elseif crate:IsA("Model") then
      return crate.PrimaryPart or crate:FindFirstChildWhichIsA("BasePart", true)
   end
   return nil
end

local function CreateCrateESP(crate, color)
   if CrateESPObjects[crate] then return end
   local part = GetCratePart(crate)
   if not part then return end

   local highlight = Instance.new("Highlight")
   highlight.Adornee = crate
   highlight.FillColor = color
   highlight.OutlineColor = color
   highlight.FillTransparency = 0.5
   highlight.OutlineTransparency = 0
   highlight.Parent = crate

   CrateESPObjects[crate] = {highlight}
end

-- FIXED: switched from GetChildren to GetDescendants to find nested crates
local function UpdateCrateESP()
   if LockpickESPEnabled then
      local ok, folder = pcall(function() return workspace.Game.Items.LockpickCrates.Special end)
      if ok and folder then
         for _, crate in pairs(folder:GetDescendants()) do
            local crateName = crate.Name
            if LockpickToggles[crateName] then
               CreateCrateESP(crate, CrateColors[crateName] or Color3.fromRGB(255, 255, 255))
            else
               RemoveCrateESP(crate)
            end
         end
      end
   else
      local ok, folder = pcall(function() return workspace.Game.Items.LockpickCrates.Special end)
      if ok and folder then
         for _, crate in pairs(folder:GetDescendants()) do
            RemoveCrateESP(crate)
         end
      end
   end

   if BoxESPEnabled then
      local ok1, commonFolder = pcall(function() return workspace.Game.Items.Boxes.Common end)
      if ok1 and commonFolder then
         for _, crate in pairs(commonFolder:GetDescendants()) do
            if BoxToggles.Common then
               CreateCrateESP(crate, CrateColors.Common)
            else
               RemoveCrateESP(crate)
            end
         end
      end

      local ok2, specialFolder = pcall(function() return workspace.Game.Items.Boxes.Special end)
      if ok2 and specialFolder then
         for _, crate in pairs(specialFolder:GetDescendants()) do
            local crateName = crate.Name
            if BoxToggles[crateName] then
               CreateCrateESP(crate, CrateColors[crateName] or Color3.fromRGB(255, 255, 255))
            else
               RemoveCrateESP(crate)
            end
         end
      end
   else
      local ok1, commonFolder = pcall(function() return workspace.Game.Items.Boxes.Common end)
      if ok1 and commonFolder then
         for _, crate in pairs(commonFolder:GetDescendants()) do
            RemoveCrateESP(crate)
         end
      end
      local ok2, specialFolder = pcall(function() return workspace.Game.Items.Boxes.Special end)
      if ok2 and specialFolder then
