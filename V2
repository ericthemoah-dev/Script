local ESPTab = Window:CreateTab("ESP", nil)
local ESPSection = ESPTab:CreateSection("ESP Settings")

local ESPEnabled = false
local BoxESP = false
local NameESP = false
local DistanceESP = false

local ESPObjects = {}
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local ESPConnection

local function RemoveESP(player)
   if ESPObjects[player] then
      for _, obj in pairs(ESPObjects[player]) do
         obj:Remove()
      end
      ESPObjects[player] = nil
   end
end

local function CreateESP(player)
   if player == LocalPlayer then return end
   RemoveESP(player)

   local objects = {}

   local box = Drawing.new("Square")
   box.Visible = false
   box.Color = Color3.fromRGB(255, 50, 50)
   box.Thickness = 1.5
   box.Filled = false
   objects.box = box

   local name = Drawing.new("Text")
   name.Visible = false
   name.Color = Color3.fromRGB(255, 255, 255)
   name.Size = 14
   name.Center = true
   name.Outline = true
   name.Text = player.Name
   objects.name = name

   local distance = Drawing.new("Text")
   distance.Visible = false
   distance.Color = Color3.fromRGB(200, 200, 200)
   distance.Size = 12
   distance.Center = true
   distance.Outline = true
   objects.distance = distance

   ESPObjects[player] = objects
end

local function UpdateESP()
   local camera = workspace.CurrentCamera
   for _, player in pairs(Players:GetPlayers()) do
      if player == LocalPlayer then continue end
      local objects = ESPObjects[player]
      if not objects then continue end

      local character = player.Character
      local hrp = character and character:FindFirstChild("HumanoidRootPart")
      local humanoid = character and character:FindFirstChildOfClass("Humanoid")

      if not hrp or not humanoid or humanoid.Health <= 0 then
         for _, obj in pairs(objects) do obj.Visible = false end
         continue
      end

      local screenPos, onScreen = camera:WorldToViewportPoint(hrp.Position)

      if not onScreen then
         for _, obj in pairs(objects) do obj.Visible = false end
         continue
      end

      local dist = math.floor((LocalPlayer.Character and
         LocalPlayer.Character:FindFirstChild("HumanoidRootPart") and
         (LocalPlayer.Character.HumanoidRootPart.Position - hrp.Position).Magnitude) or 0)

      local scaleFactor = 1 / (screenPos.Z * 0.01)
      local boxHeight = scaleFactor * 5
      local boxWidth = boxHeight * 0.65

      objects.box.Visible = BoxESP and true or false
      if BoxESP then
         objects.box.Size = Vector2.new(boxWidth, boxHeight)
         objects.box.Position = Vector2.new(screenPos.X - boxWidth / 2, screenPos.Y - boxHeight / 2)
      end

      objects.name.Visible = NameESP and true or false
      if NameESP then
         objects.name.Position = Vector2.new(screenPos.X, screenPos.Y - boxHeight / 2 - 16)
         objects.name.Text = player.Name
      end

      objects.distance.Visible = DistanceESP and true or false
      if DistanceESP then
         objects.distance.Position = Vector2.new(screenPos.X, screenPos.Y + boxHeight / 2 + 4)
         objects.distance.Text = dist .. " studs"
      end
   end
end

local function EnableESP()
   for _, player in pairs(Players:GetPlayers()) do
      CreateESP(player)
   end
   Players.PlayerAdded:Connect(CreateESP)
   Players.PlayerRemoving:Connect(RemoveESP)
   ESPConnection = RunService.RenderStepped:Connect(UpdateESP)
end

local function DisableESP()
   if ESPConnection then
      ESPConnection:Disconnect()
      ESPConnection = nil
   end
   for _, player in pairs(Players:GetPlayers()) do
      RemoveESP(player)
   end
end

