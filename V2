--     ZOMBIE ESP
-- =====================
local Divider = ESPTab:CreateDivider()
local MonsterSection = ESPTab:CreateSection("Monster ESP")

local MonsterESPObjects = {}
local MonsterESPEnabled = false
local MonsterESPConnection

local function RemoveMonsterESP(monster)
   if MonsterESPObjects[monster] then
      for _, obj in pairs(MonsterESPObjects[monster]) do
         if obj and obj.Parent then
            obj:Destroy()
         end
      end
      MonsterESPObjects[monster] = nil
   end
end

local function CreateMonsterESP(monster)
   if MonsterESPObjects[monster] then return end
   
   local highlight = Instance.new("Highlight")
   highlight.Adornee = monster
   highlight.FillColor = Color3.fromRGB(255, 0, 0)
   highlight.OutlineColor = Color3.fromRGB(255, 0, 0)
   highlight.FillTransparency = 0.4
   highlight.OutlineTransparency = 0
   highlight.Parent = monster
   
   MonsterESPObjects[monster] = {highlight}
end

local function UpdateMonsterESP()
   if MonsterESPEnabled then
      local ok, folder = pcall(function() return workspace.NPCs.Zombies end)
      if ok and folder then
         for _, monster in pairs(folder:GetDescendants()) do
            if monster:IsA("Model") or monster:IsA("BasePart") then
               CreateMonsterESP(monster)
            end
         end
      end
   else
      local ok, folder = pcall(function() return workspace.NPCs.Zombies end)
      if ok and folder then
         for _, monster in pairs(folder:GetDescendants()) do
            RemoveMonsterESP(monster)
         end
      end
   end
end

local function StartMonsterESP()
   MonsterESPConnection = RunService.Heartbeat:Connect(UpdateMonsterESP)
end

local function StopMonsterESP()
   if MonsterESPConnection then
      MonsterESPConnection:Disconnect()
      MonsterESPConnection = nil
   end
   local ok, folder = pcall(function() return workspace.NPCs.Zombies end)
   if ok and folder then
      for _, monster in pairs(folder:GetDescendants()) do
         RemoveMonsterESP(monster)
      end
   end
end

local MonsterMaster = ESPTab:CreateToggle({
   Name = "Monster ESP",
   CurrentValue = false,
   Flag = "togglemonsteresp",
   Callback = function(Value)
      MonsterESPEnabled = Value
      if Value then
         StartMonsterESP()
         Rayfield:Notify({
            Title = "Monster ESP Enabled",
            Content = "All monsters are now highlighted in red!",
            Duration = 2,
            Image = nil,
         })
      else
         StopMonsterESP()
         Rayfield:Notify({
            Title = "Monster ESP Disabled",
            Content = "Monster ESP has been turned off.",
            Duration = 2,
            Image = nil,
         })
      end
   end,
})
